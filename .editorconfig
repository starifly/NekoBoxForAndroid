root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
ktlint_code_style = intellij_idea
max_line_length = 120
# Disable rules ktlint cannot auto-fix (they'd block spotlessApply and force manual rewrites).
# The lint CI gate (Plan 002) already covers real correctness issues; Spotless here is for
# mechanical formatting only.
ktlint_standard_max-line-length = disabled
ktlint_standard_no-wildcard-imports = disabled
ktlint_standard_function-naming = disabled
ktlint_standard_property-naming = disabled
ktlint_standard_class-naming = disabled
ktlint_standard_backing-property-naming = disabled
ktlint_standard_enum-entry-name-case = disabled
ktlint_standard_filename = disabled
ktlint_standard_package-name = disabled
