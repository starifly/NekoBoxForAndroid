    <style name="AppearanceFoundation.Title" parent="TextAppearance.AppCompat.Title">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ThemeOverlay.MaterialComponents.MaterialAlertDialog.SagerNet">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.SagerNet.Dialog</item>
        <item name="buttonBarPositiveButtonStyle">
            @style/Widget.MaterialComponents.Button.TextButton.Dialog.Primary
        </item>
        <item name="buttonBarNegativeButtonStyle">
            @style/Widget.MaterialComponents.Button.TextButton.Dialog.Primary
        </item>
        <item name="buttonBarNeutralButtonStyle">
            @style/Widget.MaterialComponents.Button.TextButton.Dialog.Flush.Primary
        </item>
    </style>

    <style name="Widget.MaterialComponents.Button.TextButton.Dialog.Primary">
