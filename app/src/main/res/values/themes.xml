    </style>

    <style name="Widget.MaterialComponents.Button.TextButton.Dialog.Flush.Primary">
        <item name="android:textColor">?primaryOrTextPrimary</item>
    </style>

    <style name="Widget.MaterialComponents.Chip.Choice.SagerNet">
        <item name="textStartPadding">30dp</item>
        <item name="textEndPadding">30dp</item>
        <item name="chipBackgroundColor">@color/chip_background</item>
        <item name="android:textColor">@color/chip_text_color</item>
        <item name="checkedIconTint">?primaryOrTextPrimary</item>
        <item name="rippleColor">@color/chip_ripple_color</item>
    </style>

    <style name="Widget.SagerNet.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">@dimen/card_stroke_width</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
    </style>

    <!-- ElevatedCard: shadow + tonal surface, no stroke. -->
    <style name="Widget.SagerNet.CardView.Elevated">
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardBackgroundColor">?attr/cardElevatedSurfaceColor</item>
    </style>

    <style name="Widget.SagerNet.CardView.Tinted" parent="Widget.SagerNet.CardView">
        <item name="cardBackgroundColor">?attr/cardElevatedSurfaceColor</item>
    </style>

    <style name="ShapeAppearanceOverlay.SagerNet.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
