<resources>
    <!-- Base application theme. Migrated to Material 3 while keeping the app's
         hand-picked legacy palettes. Components that need legacy behavior get
         explicit SagerNet widget styles instead of relying on generated M3 tones. -->
    <style name="Theme.SagerNet" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="actionBarStyle">@style/Widget.MaterialComponents.ActionBar.Solid</item>
        <item name="bottomAppBarStyle">@style/Widget.SagerNet.BottomAppBar</item>
        <item name="floatingActionButtonStyle">@style/Widget.SagerNet.FloatingActionButton</item>
        <!-- Protocol/type label color; defaults to accent, Dracula overrides green. -->
        <item name="protocolColor">?attr/accentOrTextSecondary</item>
        <!-- Per-theme semantic colors; default to primary text (no visible change),
             Dracula overrides them. -->
        <item name="profileNameColor">?android:attr/textColorPrimary</item>
        <item name="statusConnectedColor">?attr/colorOnPrimary</item>
        <item name="statusStoppedColor">?attr/colorOnPrimary</item>
        <item name="statusConnectingColor">?attr/colorOnPrimary</item>
        <item name="testFailColor">@color/material_red_500</item>
        <item name="speedTextColor">?attr/colorOnPrimary</item>
        <item name="fabStoppedColor">?attr/colorOnPrimary</item>
        <item name="statusDetailColor">?attr/colorOnPrimary</item>
        <item name="statusTestingColor">?attr/colorOnPrimary</item>
        <item name="routeProxyColor">@color/color_route_proxy</item>
        <item name="navSelectedColor">?attr/colorPrimary</item>
        <!-- Default nav-drawer selected-item fill; also satisfies the
             ?itemShapeFillColor self-reference in @color/navigation_item so the
             ColorStateList resolves for every theme. Only Black overrides it;
             other themes (incl. Dracula) inherit this ?colorPrimary default. -->
        <item name="itemShapeFillColor">?colorPrimary</item>
        <item name="actionModeCloseDrawable">@drawable/ic_navigation_close</item>
        <item name="colorButtonNormal">?colorAccent</item>
        <item name="android:navigationBarColor">?colorPrimaryDark</item>
        <item name="colorPrimary">@color/material_pink_500</item>
        <item name="colorPrimaryDark">@color/material_pink_700</item>
        <item name="colorAccent">@color/material_pink_accent_200</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorMaterial100">@color/material_pink_100</item>
        <item name="colorMaterial300">@color/material_pink_300</item>
        <item name="cardElevatedSurfaceColor">@color/card_elevated_pink</item>

        <item name="accentOrTextSecondary">?colorAccent</item>
        <item name="accentOrTextPrimary">?colorAccent</item>
        <item name="primaryOrTextSecondary">?colorPrimary</item>
        <item name="primaryOrTextPrimary">?colorPrimary</item>

        <item name="fabColorBackground">?colorPrimary</item>
        <item name="selectedColorPrimary">?colorPrimary</item>
        <item name="actionBarTheme">@style/ThemeOverlay.AppCompat.Dark.ActionBar</item>
        <item name="tabTextColor">#99FFFFFF</item>
        <item name="tabSelectedTextColor">@color/white</item>
        <item name="tabIndicatorColor">@color/white</item>
        <item name="tabRippleColor">@color/white</item>
        <item name="whiteOrTextPrimary">@color/white</item>

        <item name="windowActionModeOverlay">true</item>

        <!-- Remove ActionBar but keep styles and themes -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <item name="chipStyle">@style/Widget.MaterialComponents.Chip.Choice.SagerNet</item>

        <item name="itemShapeAppearance">
            @style/ShapeAppearance.Material3.MediumComponent
        </item>

        <item name="alertDialogTheme">
            @style/ThemeOverlay.SagerNet.AlertDialog
        </item>

        <item name="materialAlertDialogTheme">
            @style/ThemeOverlay.MaterialComponents.MaterialAlertDialog.SagerNet
        </item>

        <item name="materialCardViewStyle">@style/Widget.SagerNet.CardView</item>
        <item name="textInputStyle">@style/Widget.SagerNet.TextInputLayout</item>
        <item name="popupMenuStyle">@style/Widget.SagerNet.PopupMenu</item>
        <item name="actionOverflowMenuStyle">@style/Widget.SagerNet.PopupMenu.Overflow</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.SagerNet.BottomSheetDialog</item>
        <item name="materialButtonStyle">@style/Widget.SagerNet.Button</item>

    </style>

